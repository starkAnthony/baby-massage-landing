# AmoCRM — set these in Vercel → Project → Settings → Environment Variables
# Do NOT commit real values to git.

# Account subdomain from URL: https://SUBDOMAIN.amocrm.ru
AMO_SUBDOMAIN=

# Long-lived token from: amoМаркет → Приватная интеграция → Ключи и доступы
AMO_TOKEN=

# amocrm.ru (Russia) or kommo.com (international). Default: amocrm.ru
AMO_BASE_DOMAIN=amocrm.ru

# Optional — new leads pipeline/stage (IDs from AmoCRM API or support)
# AMO_PIPELINE_ID=
# AMO_STATUS_ID=
# AMO_RESPONSIBLE_USER_ID=
